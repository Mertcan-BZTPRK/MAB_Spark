<Window x:Class="MAB_Spark.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAB_Spark - Ayarlar" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ana İçerik -->
        <TabControl Grid.Row="0" Margin="20">
            <!-- Kısaltmalar Sekmesi -->
            <TabItem Header="📝 Kısaltmalar" FontSize="14">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Başlık -->
                    <StackPanel Grid.Row="0" Margin="20,20,20,0">
                        <TextBlock Text="Metin Kısaltmaları Yönetimi" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Kısaltmalar ekleyin, düzenleyin veya silin" Foreground="Gray" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" Margin="20" Name="ShortcutsGrid" 
                              ItemsSource="{Binding Shortcuts}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              BorderThickness="1" BorderBrush="#E0E0E0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kısaltma" Binding="{Binding ShortText}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Genişletilmiş Metin" Binding="{Binding ExpandedText}" Width="*" IsReadOnly="False"/>
                            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsEnabled}" Width="60"/>
                            <DataGridTemplateColumn Header="İşlemler" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,5,0">
                                            <Button Content="Sil" Click="DeleteButton_Click" 
                                                    Background="#FF6B6B" Foreground="White" Padding="8,4" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Yeni Kısaltma Ekleme -->
                    <Grid Grid.Row="2" Margin="20" Background="#F9F9F9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Text="Yeni:" VerticalAlignment="Center" FontWeight="Bold" Margin="15,15,10,15"/>
                        <TextBox Grid.Column="1" Name="ShortTextBox" Padding="8" BorderThickness="1" BorderBrush="#D0D0D0" Margin="0,15,0,15"/>
                        <TextBlock Grid.Column="2" Text="→" VerticalAlignment="Center" Margin="10,0,10,0" FontSize="16" FontWeight="Bold"/>
                        <TextBox Grid.Column="3" Name="ExpandedTextBox" Padding="8" BorderThickness="1" BorderBrush="#D0D0D0" Margin="0,15,10,15"/>
                        <Button Grid.Column="4" Content="➕ Ekle" Click="AddButton_Click" Background="#4CAF50" Foreground="White" Padding="15,8" FontSize="12" Cursor="Hand" Margin="0,15,15,15"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Ayarlar Sekmesi -->
            <TabItem Header="⚙️ Ayarlar" FontSize="14">
                <Grid Background="White">
                    <StackPanel VerticalAlignment="Top" Margin="20">
                        <!-- Auto-Start -->
                        <Border BorderThickness="1" BorderBrush="#E0E0E0" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Windows Başlangıcında Çalıştır" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <CheckBox Name="AutoStartCheckBox" Content="Uygulamayı Windows başlangıcında otomatik olarak başlat" 
                                          Checked="AutoStartCheckBox_Checked" Unchecked="AutoStartCheckBox_Unchecked" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Durum Bilgisi -->
                        <Border BorderThickness="1" BorderBrush="#E0E0E0" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Durum Bilgisi" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Name="StatusText" Text="Uygulama çalışıyor..." Foreground="Green" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Name="ShortcutsCountText" Text="Toplam kısaltma: 0" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Name="DatabasePathText" Text="" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Hakkında -->
                        <Border BorderThickness="1" BorderBrush="#E0E0E0" Padding="15" CornerRadius="5">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Hakkında" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="MAB_Spark v1.0" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="TextBlaze benzeri metin genişletme uygulaması" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                                <TextBlock Text="© 2024 MAB_Spark Project" Foreground="Gray" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Alt Butonlar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
            <Button Name="MinimizeButton" Content="❌ Kapat" Click="MinimizeButton_Click" 
                    Background="#757575" Foreground="White" Padding="15,8" FontSize="12" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
