<Window x:Class="MAB_Spark.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="650" Width="950"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewMouseDown="Window_PreviewMouseDown"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BgColor">#0F0F1E</Color>
        <Color x:Key="AccentColor">#6366F1</Color>
        <SolidColorBrush x:Key="GlassBg" Color="#0F0F1E" Opacity="0.85"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>

        <!-- Button Style -->
        <Style x:Key="ModernBtn" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="#1A1A2E" BorderBrush="{TemplateBinding BorderBrush}" 
                               BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Opacity="0.7">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#6366F1" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
        </Style>
    </Window.Resources>

    <!-- Main Container -->
    <Border CornerRadius="16" Background="{StaticResource GlassBg}" 
            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Color="#000000" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0F0F1E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="30,20,30,20" VerticalAlignment="Center">
                        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                        <TextBlock Text="Manage your shortcuts" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Button Name="ThemeToggleButton" Content="🌙" Click="ThemeToggle_Click" 
                               Style="{StaticResource SmallBtn}" Margin="0,0,5,0"/>
                        <Button Content="✕" Click="Close_Click" Style="{StaticResource SmallBtn}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Foreground="#FFFFFF" Background="Transparent" 
                       BorderThickness="0" Margin="30,20,30,20">
                <!-- Shortcuts Tab -->
                <TabItem Header="📝 Shortcuts" FontSize="13">
                    <Grid Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="0" Name="ShortcutsGrid" ItemsSource="{Binding Shortcuts}"
                                 AutoGenerateColumns="False" CanUserAddRows="False"
                                 Background="#1A1A2E" Foreground="#FFFFFF"
                                 BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                 Margin="0,0,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Short" Binding="{Binding ShortText}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Expanded" Binding="{Binding ExpandedText}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsEnabled}" Width="60"/>
                                <DataGridTemplateColumn Header="Action" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" Click="DeleteButton_Click" 
                                                   Style="{StaticResource ModernBtn}" Padding="6,3" FontSize="10"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Add Shortcut -->
                        <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="{StaticResource AccentBrush}" 
                               BorderThickness="1" CornerRadius="8">
                            <Grid Margin="15,15,15,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="New:" Foreground="#FFFFFF" VerticalAlignment="Center" 
                                          FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Name="ShortTextBox" Background="#0F0F1E"
                                        Foreground="#FFFFFF" BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1" Padding="8"/>
                                <TextBlock Grid.Column="2" Text="→" Foreground="{StaticResource AccentBrush}"
                                          FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBox Grid.Column="3" Name="ExpandedTextBox" Background="#0F0F1E"
                                        Foreground="#FFFFFF" BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1" Padding="8" Margin="0,0,10,0"/>
                                <Button Grid.Column="4" Content="Add" Click="AddButton_Click"
                                       Style="{StaticResource ModernBtn}" Padding="14,8"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Settings Tab -->
                <TabItem Header="⚙️ Settings" FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,20">
                            <!-- Auto-Start -->
                            <Border Background="#1A1A2E" BorderBrush="{StaticResource AccentBrush}"
                                   BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                                <StackPanel Margin="20,20,20,20">
                                    <TextBlock Text="Startup" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <CheckBox Name="AutoStartCheckBox" Content="Start with Windows"
                                             Foreground="#FFFFFF" Checked="AutoStartCheckBox_Checked"
                                             Unchecked="AutoStartCheckBox_Unchecked" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Status -->
                            <Border Background="#1A1A2E" BorderBrush="#06B6D4" BorderThickness="1"
                                   CornerRadius="8" Margin="0,0,0,15">
                                <StackPanel Margin="20,20,20,20">
                                    <TextBlock Text="Status" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock Name="StatusText" Text="Running..." Foreground="#10B981" 
                                              Margin="0,8,0,5" FontSize="11"/>
                                    <TextBlock Name="ShortcutsCountText" Text="Shortcuts: 0"
                                              Foreground="#9CA3AF" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Name="DatabasePathText" Text="" Foreground="#9CA3AF"
                                              FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- About -->
                            <Border Background="#1A1A2E" BorderBrush="#EC4899" BorderThickness="1"
                                   CornerRadius="8">
                                <StackPanel Margin="20,20,20,20">
                                    <TextBlock Text="About" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock Text="MAB_Spark v2.0 - Modern Edition" Foreground="#FFFFFF" 
                                              Margin="0,8,0,3" FontSize="11"/>
                                    <TextBlock Text="Glassmorphism UI • Dark/Light Theme" Foreground="#9CA3AF"
                                              FontSize="10"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#0F0F1E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="© 2024 MAB_Spark" Foreground="#9CA3AF" FontSize="10"
                          Margin="0,12,0,12" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
