<Window x:Class="MAB_Spark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="MAB_Spark" 
        Height="500" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        PreviewMouseDown="Window_PreviewMouseDown"
        ResizeMode="CanResize"
        
        Closing="Window_Closing"
       >

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BgColor">#0F0F1E</Color>
        <Color x:Key="AccentColor">#6366F1</Color>
        <SolidColorBrush x:Key="GlassBg" Color="#0F0F1E" Opacity="0.85"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>

        <!-- Button Styles -->
        <Style x:Key="NeonButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="Transparent">
                            <Border Background="#1A1A2E" BorderBrush="#6366F1" 
                                   BorderThickness="1.5" CornerRadius="8" Opacity="0.7">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" 
                                                    Color="#6366F1" Opacity="0.2"/>
                                </Border.Effect>
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NeonButtonStyle}">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <!-- Main Glass Container -->
    <Border CornerRadius="16" Background="{StaticResource GlassBg}" 
            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Color="#000000" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0F0F1E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="30,20,30,20" VerticalAlignment="Center">
                        <TextBlock Text="MAB_Spark" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"/>
                        <TextBlock Text="Modern Text Expansion Tool" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Button Name="ThemeBtn" Content="🌙" Click="ThemeToggle_Click" 
                               Style="{StaticResource IconButtonStyle}" Margin="0,0,5,0"/>
                        <Button Content="✕" Click="CloseWindow_Click" 
                               Style="{StaticResource IconButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,30,40,30">
                    <!-- Title -->
                    <TextBlock Text="Dashboard" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>

                    <!-- Status Card -->
                    <Border Background="#1A1A2E" BorderBrush="{StaticResource AccentBrush}" 
                           BorderThickness="1" CornerRadius="10" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#6366F1" Opacity="0.15"/>
                        </Border.Effect>
                        <StackPanel Margin="20,20,20,20">
                            <TextBlock Text="Application Status" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="Running in background..." FontSize="11" 
                                      Foreground="#9CA3AF" Margin="0,8,0,0"/>
                            <Separator Background="#6366F1" Opacity="0.2" Margin="0,12,0,12" Height="1"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shortcuts Available" FontSize="11" Foreground="#9CA3AF"/>
                                <TextBlock Name="ShortcutCountBlock" Grid.Column="1" Text="0" 
                                          FontSize="16" FontWeight="Bold" Foreground="#6366F1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,20">
                        <Button Content="⚙️ Settings" Click="OpenSettings_Click" 
                               Style="{StaticResource NeonButtonStyle}" Margin="0,0,10,0" MinWidth="140"/>
                        <Button Content="📊 Show" Click="ShowWindow_Click" 
                               Style="{StaticResource NeonButtonStyle}" MinWidth="140"/>
                    </StackPanel>

                    <!-- Info Cards -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#1A1A2E" BorderBrush="#EC4899" BorderThickness="1" 
                               CornerRadius="8" Margin="0,0,5,0">
                            <StackPanel Margin="15,15,15,15">
                                <TextBlock Text="Quick Start" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF"/>
                                <TextBlock Text="Right-click tray icon" FontSize="10" Foreground="#9CA3AF" 
                                          Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#1A1A2E" BorderBrush="#06B6D4" BorderThickness="1" 
                               CornerRadius="8" Margin="5,0,0,0">
                            <StackPanel Margin="15,15,15,15">
                                <TextBlock Text="Features" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF"/>
                                <TextBlock Text="Dark/Light • Auto-Expand" FontSize="10" Foreground="#9CA3AF" 
                                          Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#0F0F1E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="© 2024 MAB_Spark" Foreground="#9CA3AF" FontSize="10" 
                          Margin="0,15,0,15" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>

