<Window x:Class="MAB_Spark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="MAB_Spark" Height="1" Width="1" 
        ShowInTaskbar="False"
        WindowStyle="None"
        Opacity="0">
    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="MAB_Spark - Metin Genişletme">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="⚙️ Ayarlar" Click="ShowSettings_Click"/>
                    <Separator/>
                    <MenuItem Header="❌ Çıkış" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
